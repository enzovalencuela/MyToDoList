generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========== TABELAS EXISTENTES (somente leitura, não alterar) ==========

model Usuario {
  id_usuario   Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  firebase_uid String?   @unique
  foto_perfil  String?
  data_criacao DateTime? @default(now())
  tarefas      Tarefa[]
  weeklyTasks  WeeklyTask[]

  @@map("usuario")
}

model Tarefa {
  id_tarefa     Int       @id @default(autoincrement())
  titulo        String
  descricao     String?
  data_prazo    DateTime? @db.Date
  prioridade    String    @default("Normal")
  estado_tarefa String    @default("Pendente")
  ordem         Int       @default(0)
  id_usuario    Int
  usuario       Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("tarefa")
}

model WeeklyTask {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  dayOfWeek Int
  startTime String
  endTime   String
  category  String?
  userId    Int      @map("id_usuario")
  user      Usuario  @relation(fields: [userId], references: [id_usuario], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, dayOfWeek, startTime])
  @@map("weekly_task")
}

// ========== TABELAS NOVAS (NextAuth) ==========

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("next_auth_user")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("next_auth_account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("next_auth_session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("next_auth_verification_token")
}
